# IRM Sentinel Environment Configuration
# Copy to .env.local for local development
# NEVER commit actual credentials to version control

# Environment: development | staging | production
VITE_ENV=development

# Application
VITE_APP_VERSION=1.0.0
VITE_BUILD_HASH=dev

# Authentication Mode: demo (local dev only) | supabase | oidc
# CISO-001: demo mode is blocked in production/staging
VITE_AUTH_MODE=demo

# Supabase Configuration
# CISO-002: These values must be set via Vercel Environment Variables in prod
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_SUPABASE_SCHEMA=irm

# Tenant Configuration
VITE_TENANT_ID=TNT-001
VITE_TENANT_NAME=Development Tenant
VITE_TENANT_REGION=us-east-1

# OIDC/SSO Configuration (required for production)
VITE_OIDC_ISSUER=https://your-idp.okta.com/oauth2/default
VITE_OIDC_CLIENT_ID=your-client-id
VITE_OIDC_REDIRECT_URI=https://your-app.com/auth/callback
VITE_OIDC_LOGOUT_URI=https://your-app.com/auth/logout
VITE_OIDC_SCOPES=openid profile email irm:read irm:write

# SIEM/Telemetry (recommended for production)
VITE_SIEM_ENDPOINT=https://your-siem.example.com/api/events
VITE_SIEM_API_KEY=your-siem-api-key
